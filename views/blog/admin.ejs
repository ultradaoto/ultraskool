<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: 'Blog Admin | Ultra Skool', description: 'Manage Ultra Skool blog posts.' }) %>
<body>
    <%- include('../partials/header') %>
    <main class="main-page">
        <div class="container-custom py-8 md:py-12">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
                <div>
                    <h1 class="title text-4xl md:text-5xl">Blog Admin</h1>
                    <p class="mt-1 text-[#cfc6f8]/60">Manage your blog posts</p>
                </div>
                <a href="/admin/blog/new" class="quantum-button inline-flex items-center gap-2 !px-6 !py-3 !text-base">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    New Post
                </a>
            </div>

            <% if (posts && posts.length > 0) { %>
                <div class="surface-table">
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="border-b border-white/8 bg-white/5">
                                <tr>
                                    <th class="px-6 py-4 text-left text-sm font-medium text-[#d9d1fb]/76">Post</th>
                                    <th class="px-6 py-4 text-left text-sm font-medium text-[#d9d1fb]/76">Status</th>
                                    <th class="px-6 py-4 text-left text-sm font-medium text-[#d9d1fb]/76">Date</th>
                                    <th class="px-6 py-4 text-left text-sm font-medium text-[#d9d1fb]/76">Tags</th>
                                    <th class="px-6 py-4 text-right text-sm font-medium text-[#d9d1fb]/76">Actions</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/8">
                                <% posts.forEach(post => { %>
                                    <tr class="transition-colors hover:bg-white/4">
                                        <td class="px-6 py-4">
                                            <div>
                                                <a href="/blog/<%= post.slug %>" target="_blank" class="font-medium text-purple-300 transition-colors hover:text-white"><%= post.title %></a>
                                                <p class="mt-1 text-sm text-[#cfc6f8]/52"><%= post.slug %></p>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <% if (post.published) { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                                                    Published
                                                </span>
                                            <% } else { %>
                                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                                    <span class="w-1.5 h-1.5 bg-yellow-500 rounded-full"></span>
                                                    Draft
                                                </span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-sm text-[#e0e0ff]/72">
                                            <div>
                                                <span>Created: <%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                                                <% if (post.updatedAt !== post.createdAt) { %>
                                                    <p class="mt-0.5 text-xs text-[#cfc6f8]/45">Updated: <%= new Date(post.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-wrap gap-1 max-w-xs">
                                                <% post.tags.slice(0, 3).forEach(tag => { %>
                                                    <span class="style-chip text-xs"><%= tag %></span>
                                                <% }) %>
                                                <% if (post.tags.length > 3) { %>
                                                    <span class="style-chip text-xs">+<%= post.tags.length - 3 %></span>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex items-center justify-end gap-2">
                                                <a href="/blog/<%= post.slug %>" target="_blank" class="rounded-lg p-2 text-[#cfc6f8]/55 transition-colors hover:bg-white/8 hover:text-white" title="View">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                                                </a>
                                                <a href="/admin/blog/edit/<%= post.id %>" class="rounded-lg p-2 text-[#cfc6f8]/55 transition-colors hover:bg-white/8 hover:text-white" title="Edit">
                                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                                                </a>
                                                <form action="/admin/blog/delete/<%= post.id %>" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to delete this post? This action cannot be undone.');">
                                                    <button type="submit" class="rounded-lg p-2 text-[#cfc6f8]/55 transition-colors hover:bg-red-500/12 hover:text-red-300" title="Delete">
                                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            <% } else { %>
                <div class="section-shell p-12 text-center">
                    <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-white/6">
                        <svg class="h-8 w-8 text-[#cfc6f8]/48" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                    </div>
                    <h3 class="mb-2 font-cormorant text-2xl text-white">No posts yet</h3>
                    <p class="mb-6 text-[#cfc6f8]/58">Get started by creating your first blog post.</p>
                    <a href="/admin/blog/new" class="quantum-button inline-flex items-center gap-2 !px-6 !py-3 !text-base">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Create First Post
                    </a>
                </div>
            <% } %>
        </div>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>
