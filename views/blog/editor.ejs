<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: isNew ? 'New Blog Post | Ultra Skool' : 'Edit Blog Post | Ultra Skool', description: 'Create or edit Ultra Skool blog content.' }) %>
<body>
    <%- include('../partials/header') %>
    <main class="main-page">
        <div class="container-custom py-8 md:py-12">
            <div class="mb-8">
                <a href="/admin/blog" class="flex items-center gap-2 text-sm text-purple-300 transition-colors hover:text-white">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                    Back to Admin
                </a>
            </div>

            <div class="max-w-4xl mx-auto">
                <h1 class="title mb-8 text-4xl md:text-5xl">
                    <%= isNew ? 'New Post' : 'Edit Post' %>
                </h1>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="mb-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3 text-red-200">
                        <%= error %>
                    </div>
                <% } %>

                <form action="<%= isNew ? '/admin/blog/new' : `/admin/blog/edit/${post.id}` %>" method="POST" class="section-shell p-6 md:p-8">
                    <div class="space-y-6">
                        <!-- Title -->
                        <div>
                            <label for="title" class="mb-2 block text-sm font-medium text-[#e7e1ff]">Title *</label>
                            <input type="text" id="title" name="title" required
                                value="<%= post?.title || '' %>"
                                class="surface-input"
                                placeholder="Enter post title">
                        </div>

                        <!-- Slug -->
                        <div>
                            <label for="slug" class="mb-2 block text-sm font-medium text-[#e7e1ff]">
                                Slug
                                <span class="font-normal text-[#bfb3ea]/55">(URL-friendly identifier, auto-generated if empty)</span>
                            </label>
                            <input type="text" id="slug" name="slug"
                                value="<%= post?.slug || '' %>"
                                class="surface-input"
                                placeholder="e.g., my-awesome-post">
                        </div>

                        <!-- Excerpt -->
                        <div>
                            <label for="excerpt" class="mb-2 block text-sm font-medium text-[#e7e1ff]">
                                Excerpt
                                <span class="font-normal text-[#bfb3ea]/55">(Short summary for listings)</span>
                            </label>
                            <textarea id="excerpt" name="excerpt" rows="3"
                                class="surface-input resize-none"
                                placeholder="Brief description of the post"><%= post?.excerpt || '' %></textarea>
                        </div>

                        <!-- Content -->
                        <div>
                            <label for="content" class="mb-2 block text-sm font-medium text-[#e7e1ff]">
                                Content *
                                <span class="font-normal text-[#bfb3ea]/55">(HTML supported)</span>
                            </label>
                            <textarea id="content" name="content" rows="15" required
                                class="surface-input font-mono text-sm"
                                placeholder="<p>Your post content here...</p>"><%= post?.content || '' %></textarea>
                            <p class="mt-2 text-xs text-[#cfc6f8]/52">
                                Tip: Use HTML tags like &lt;p&gt;, &lt;h2&gt;, &lt;ul&gt;, &lt;li&gt;, &lt;strong&gt; to format your content.
                            </p>
                        </div>

                        <!-- Two Column Layout for Meta Fields -->
                        <div class="grid md:grid-cols-2 gap-6">
                            <!-- Author -->
                            <div>
                                <label for="author" class="mb-2 block text-sm font-medium text-[#e7e1ff]">Author</label>
                                <input type="text" id="author" name="author"
                                    value="<%= post?.author || 'Sterling Cooley' %>"
                                    class="surface-input">
                            </div>

                            <!-- Tags -->
                            <div>
                                <label for="tags" class="mb-2 block text-sm font-medium text-[#e7e1ff]">
                                    Tags
                                    <span class="font-normal text-[#bfb3ea]/55">(comma-separated)</span>
                                </label>
                                <input type="text" id="tags" name="tags"
                                    value="<%= post?.tags ? post.tags.join(', ') : '' %>"
                                    class="surface-input"
                                    placeholder="ultra-breath, microtubules, consciousness">
                            </div>
                        </div>

                        <!-- Social Links -->
                        <div class="border-t border-white/8 pt-6">
                            <h3 class="mb-4 text-sm font-medium text-[#e7e1ff]">Social Links</h3>
                            <div class="grid md:grid-cols-2 gap-6">
                                <div>
                                    <label for="twitter" class="mb-2 block text-sm text-[#cfc6f8]/66">Twitter URL</label>
                                    <input type="url" id="twitter" name="twitter"
                                        value="<%= post?.socialLinks?.twitter || '' %>"
                                        class="surface-input"
                                        placeholder="https://twitter.com/...">
                                </div>
                                <div>
                                    <label for="youtube" class="mb-2 block text-sm text-[#cfc6f8]/66">YouTube URL</label>
                                    <input type="url" id="youtube" name="youtube"
                                        value="<%= post?.socialLinks?.youtube || '' %>"
                                        class="surface-input"
                                        placeholder="https://youtube.com/...">
                                </div>
                            </div>
                        </div>

                        <!-- Published Toggle -->
                        <div class="border-t border-white/8 pt-6">
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" id="published" name="published"
                                    <%= post?.published ? 'checked' : '' %>
                                    class="h-5 w-5 rounded border-white/15 bg-[#0d0f1d] text-purple-400 focus:ring-purple-500/20">
                                <span class="text-[#e7e1ff]">Publish this post</span>
                                <span class="text-sm text-[#bfb3ea]/55">(Uncheck to save as draft)</span>
                            </label>
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="mt-8 flex items-center gap-4 border-t border-white/8 pt-6">
                        <button type="submit" class="quantum-button !px-6 !py-3 !text-base">
                            <%= isNew ? 'Create Post' : 'Save Changes' %>
                        </button>
                        <a href="/admin/blog" class="px-2 py-3 text-[#cfc6f8]/62 transition-colors hover:text-white">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>
    <%- include('../partials/footer') %>

    <script>
        // Auto-generate slug from title
        const titleInput = document.getElementById('title');
        const slugInput = document.getElementById('slug');
        
        titleInput?.addEventListener('blur', () => {
            if (!slugInput.value && titleInput.value) {
                slugInput.value = titleInput.value
                    .toLowerCase()
                    .replace(/[^a-z0-9]+/g, '-')
                    .replace(/^-+|-+$/g, '');
            }
        });
    </script>
</body>
</html>
