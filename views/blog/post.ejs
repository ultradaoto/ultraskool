<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: post.title, description: post.excerpt || 'Ultra Skool article' }) %>
<body>
    <%- include('../partials/header') %>
    <main class="main-page">
        <div class="container-custom py-8 md:py-16">
            <article class="max-w-3xl mx-auto">
                <header class="hero-shell mb-8 md:mb-12">
                    <div class="flex flex-wrap gap-2 mb-4">
                        <% post.tags.forEach(tag => { %>
                            <a href="/blog/tag/<%= tag %>" class="style-chip text-sm transition-colors hover:bg-purple-500/20"><%= tag %></a>
                        <% }) %>
                    </div>
                    <h1 class="font-cormorant text-4xl md:text-5xl text-white mb-4 font-medium leading-tight"><%= post.title %></h1>
                    <div class="flex flex-wrap items-center gap-4 text-sm text-[#cfc6f8]/60 md:text-base">
                        <span>By <strong class="text-purple-300"><%= post.author %></strong></span>
                        <span>&bull;</span>
                        <span><%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                        <% if (post.updatedAt !== post.createdAt) { %>
                            <span>&bull;</span>
                            <span>Updated <%= new Date(post.updatedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
                        <% } %>
                    </div>
                </header>

                <div class="section-shell blog-prose mb-12 max-w-none">
                    <%- post.content %>
                </div>

                <% if (post.socialLinks && (post.socialLinks.twitter || post.socialLinks.youtube)) { %>
                <div class="mb-12 border-t border-white/8 pt-6">
                    <p class="mb-3 text-sm text-[#cfc6f8]/58">Connect with us:</p>
                    <div class="flex gap-4">
                        <% if (post.socialLinks.twitter) { %>
                            <a href="<%= post.socialLinks.twitter %>" target="_blank" rel="noopener" class="flex items-center gap-2 text-purple-300 transition-colors hover:text-white">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                                <span>Twitter</span>
                            </a>
                        <% } %>
                        <% if (post.socialLinks.youtube) { %>
                            <a href="<%= post.socialLinks.youtube %>" target="_blank" rel="noopener" class="flex items-center gap-2 text-purple-300 transition-colors hover:text-white">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                                <span>YouTube</span>
                            </a>
                        <% } %>
                    </div>
                </div>
                <% } %>

                <div class="border-t border-white/8 pt-8">
                    <a href="/blog" class="flex items-center gap-2 text-purple-300 transition-colors hover:text-white">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
                        Back to all posts
                    </a>
                </div>
            </article>

            <% if (relatedPosts && relatedPosts.length > 0) { %>
            <section class="mt-16 border-t border-white/8 pt-12">
                <h2 class="mb-8 text-center font-cormorant text-3xl font-medium text-white">Related Posts</h2>
                <div class="grid md:grid-cols-3 gap-6">
                    <% relatedPosts.forEach(related => { %>
                        <article class="style-panel">
                            <div>
                                <div class="flex flex-wrap gap-1 mb-2">
                                    <% related.tags.slice(0, 2).forEach(tag => { %>
                                        <span class="style-chip text-xs"><%= tag %></span>
                                    <% }) %>
                                </div>
                                <h3 class="mb-2 font-cormorant text-lg font-medium text-white">
                                    <a href="/blog/<%= related.slug %>" class="transition-colors hover:text-purple-300"><%= related.title %></a>
                                </h3>
                                <p class="text-sm text-[#e0e0ff]/72 line-clamp-2"><%= related.excerpt %></p>
                            </div>
                        </article>
                    <% }) %>
                </div>
            </section>
            <% } %>
        </div>
    </main>
    <%- include('../partials/footer') %>
</body>
</html>
