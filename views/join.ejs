<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Ultra Skool Workshop', description: 'Join live Ultra Skool workshops, calendar access, and community sessions.' }) %>
<body>
    <%- include('partials/header') %>
    <main class="main-page">
        <div class="container-custom">
            <section class="hero-shell">
                <div class="page-orb left-[-4rem] top-12 h-44 w-44 bg-purple-500/16"></div>
                <div class="page-orb bottom-[-5rem] right-[-2rem] h-56 w-56 bg-fuchsia-500/12"></div>

                <div class="relative z-10 text-center">
                    <span class="style-kicker mb-6">Live Access</span>
                    <h1 class="title mb-4">Live Quantum Workshops</h1>
                    <p class="subtitle">Experience Advanced Consciousness Engineering Live</p>
                    <p class="mx-auto mt-6 max-w-3xl text-lg text-[#e0e0ff]/84 md:text-xl">
                        We hold regular, high-impact live workshops where we explore advanced ultrasound stimulation techniques, quantum biology, and consciousness expansion together.
                    </p>
                    <p class="mx-auto mt-4 max-w-2xl text-lg text-purple-300/90">Join our community of pioneers to learn, ask questions, and practice with advanced VNS tools in real-time.</p>
                </div>
            </section>

            <section class="mx-auto mt-8 grid max-w-[960px] gap-6 md:grid-cols-2">
                <div class="section-shell flex flex-col justify-between text-center">
                    <div>
                        <p class="section-label">Calendar</p>
                        <h3 class="mt-4 font-cormorant text-3xl text-white">Upcoming Events</h3>
                        <p class="mt-4 text-[#e0e0ff]/82">View our full schedule of live sessions, guest lectures, and collective practice events.</p>
                    </div>
                    <a href="https://skool.com/ultra/calendar" target="_blank" class="quantum-button mt-8 !px-6 !py-3 !text-lg">
                        View Workshop Calendar
                    </a>
                </div>

                <div class="section-shell flex flex-col justify-between text-center">
                    <div>
                        <p class="section-label">Trial access</p>
                        <h3 class="mt-4 font-cormorant text-3xl text-white">7-Day Free Trial</h3>
                        <p class="mt-4 text-[#e0e0ff]/82">Get full access to the Ultra Skool modules, community, and live recordings for 7 days - completely free.</p>
                    </div>
                    <a href="https://skool.com/ultra" target="_blank" class="quantum-button mt-8 !px-6 !py-3 !text-lg">
                        Start Free Trial
                    </a>
                </div>
            </section>

            <div class="mt-14 text-center space-y-4">
                <p class="text-lg italic text-purple-300/88">Don't miss our next live transmission.</p>
                <p class="text-sm text-[#d4cdf8]/72">Experience the synergy of collective consciousness engineering.</p>
            </div>
        </div>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
